"""
Tests for enhanced /api/ubid/list endpoint with filtering capabilities.
"""
import pytest
from fastapi.testclient import TestClient
from sqlalchemy import create_engine
from sqlalchemy.orm import sessionmaker
from src.api.main import app
from src.database.models import Base, UBIDEntity, UBIDSourceLink, ActivityScore
from src.database.connection import get_db
from datetime import datetime
import uuid


# Create in-memory SQLite database for testing
SQLALCHEMY_DATABASE_URL = "sqlite:///:memory:"
engine = create_engine(
    SQLALCHEMY_DATABASE_URL,
    connect_args={"check_same_thread": False}
)
TestingSessionLocal = sessionmaker(autocommit=False, autoflush=False, bind=engine)


def override_get_db():
    """Override the database dependency for testing."""
    try:
        db = TestingSessionLocal()
        yield db
    finally:
        db.close()


app.dependency_overrides[get_db] = override_get_db
client = TestClient(app)


@pytest.fixture(scope="function")
def setup_database():
    """Create tables and populate with test data."""
    Base.metadata.create_all(bind=engine)
    db = TestingSessionLocal()
    
    # Create test UBIDs with different characteristics
    test_data = [
        {
            "ubid": "KA-UBID-000001",
            "pan_anchor": "AAAAA1111A",
            "gstin_anchors": ["29AAAAA1111A1Z5"],
            "anchor_status": "ANCHORED",
            "activity_status": "ACTIVE",
            "link_count": 2,
            "departments": ["shop_establishment", "factories"]
        },
        {
            "ubid": "KA-UBID-000002",
            "pan_anchor": None,
            "gstin_anchors": [],
            "anchor_status": "UNANCHORED",
            "activity_status": "DORMANT",
            "link_count": 1,
            "departments": ["labour"]
        },
        {
            "ubid": "KA-UBID-000003",
            "pan_anchor": "BBBBB2222B",
            "gstin_anchors": ["29BBBBB2222B1Z5"],
            "anchor_status": "ANCHORED",
            "activity_status": "ACTIVE",
            "link_count": 3,
            "departments": ["shop_establishment", "factories", "kspcb"]
        },
        {
            "ubid": "KA-UBID-000004",
            "pan_anchor": "CCCCC3333C",
            "gstin_anchors": ["29CCCCC3333C1Z5"],
            "anchor_status": "ANCHORED",
            "activity_status": "CLOSED_SUSPECTED",
            "link_count": 4,
            "departments": ["shop_establishment", "factories", "labour", "kspcb"]
        },
    ]
    
    for data in test_data:
        # Create UBID entity
        entity = UBIDEntity(
            ubid=data["ubid"],
            pan_anchor=data["pan_anchor"],
            gstin_anchors=data["gstin_anchors"],
            anchor_status=data["anchor_status"],
            created_at=datetime.utcnow()
        )
        db.add(entity)
        
        # Create activity score
        activity = ActivityScore(
            score_id=str(uuid.uuid4()),
            ubid=data["ubid"],
            raw_score=0.8,
            activity_status=data["activity_status"],
            is_current=True,
            computed_at=datetime.utcnow()
        )
        db.add(activity)
        
        # Create source links
        for i, dept in enumerate(data["departments"]):
            link = UBIDSourceLink(
                link_id=str(uuid.uuid4()),
                ubid=data["ubid"],
                source_system=dept,
                source_record_id=f"{dept}_{data['ubid']}_{i}",
                confidence=0.95,
                link_type="auto",
                linked_by="system",
                is_active=True,
                linked_at=datetime.utcnow()
            )
            db.add(link)
    
    db.commit()
    db.close()
    
    yield
    
    # Cleanup
    Base.metadata.drop_all(bind=engine)


def test_list_ubids_no_filters(setup_database):
    """Test basic list endpoint without filters."""
    response = client.get("/api/ubid/list")
    assert response.status_code == 200
    data = response.json()
    
    assert "total" in data
    assert "page" in data
    assert "page_size" in data
    assert "results" in data
    assert data["total"] == 4
    assert len(data["results"]) == 4


def test_list_ubids_with_pagination(setup_database):
    """Test pagination parameters."""
    response = client.get("/api/ubid/list?page=1&page_size=2")
    assert response.status_code == 200
    data = response.json()
    
    assert data["total"] == 4
    assert data["page"] == 1
    assert data["page_size"] == 2
    assert len(data["results"]) == 2


