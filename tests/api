def test_list_ubids_cache_key_includes_filters(setup_database):
    """Test that different filter combinations use different cache keys."""
    # First request
    response1 = client.get("/api/ubid/list?activity_status=ACTIVE")
    assert response1.status_code == 200
    data1 = response1.json()
    
    # Second request with different filter
    response2 = client.get("/api/ubid/list?activity_status=DORMANT")
    assert response2.status_code == 200
    data2 = response2.json()
    
    # Results should be different
    assert data1["total"] != data2["total"]


def test_list_ubids_response_structure(setup_database):
    """Test that response has correct structure."""
    response = client.get("/api/ubid/list")
    assert response.status_code == 200
    data = response.json()
    
    # Check top-level structure
    assert "total" in data
    assert "page" in data
    assert "page_size" in data
    assert "results" in data
    
    # Check result item structure
    if len(data["results"]) > 0:
        result = data["results"][0]
        assert "ubid" in result
        assert "display_name" in result
        assert "pan_anchor" in result
        assert "gstin_anchors" in result
        assert "activity_status" in result
        assert "anchor_status" in result
        assert "source_record_count" in result
